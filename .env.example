# Copy to .env and adjust. Values starting with CHANGE-THIS trigger a
# security warning in the logs until replaced.

# --- Security (required) ---
SECRET_KEY=CHANGE-THIS-IN-PRODUCTION-USE-SECRETS
ADMIN_BOOTSTRAP_TOKEN=CHANGE-THIS-BOOTSTRAP-TOKEN

# --- CORS: origins allowed to call the API (JSON list) ---
ALLOWED_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# --- Optional overrides (sensible defaults exist for all of these) ---
# DATABASE_URL=sqlite:///aipr_storage.db
# MODEL_PATH=runs/experiment/run_01/best_model.pt   # skip auto-discovery
# DEVICE=cuda                                       # cpu | cuda | mps (auto-detected by default)
# ACCESS_TOKEN_EXPIRE_MINUTES=1440
# MAX_UPLOAD_SIZE_MB=20
# BATCH_INFERENCE_SIZE=16
